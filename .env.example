# LJIET_Attendance - Copy to .env and fill in values
# SECRET_KEY=your-secret-key-here
# DEBUG=False
# ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
# DATABASE_URL=sqlite:///db.sqlite3

# Email (for mentor notifications, attendance alerts)
# Development: use console backend (emails print to terminal)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Production: use SMTP (Gmail, Outlook, etc.)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=LJIET Attendance <your-email@gmail.com>
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# PythonAnywhere: replace YOUR_USERNAME with your PA username
# ALLOWED_HOSTS=YOUR_USERNAME.pythonanywhere.com
